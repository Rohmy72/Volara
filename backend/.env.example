# Copy this file to .env in the same directory and fill in what you need.
# Every value below is optional — the app works with no keys at all.

# Optional: enables the Alpha Vantage NEWS_SENTIMENT feed as an extra news
# source (adds per-article ticker relevance + sentiment scores). Free tier
# signup: https://www.alphavantage.co/support/#api-key
# Free tier is rate-limited (5 req/min, 25 req/day) so leave unset if you
# don't need it — the app already uses yfinance + Google/Yahoo RSS by default.
AV_KEY=

# Benchmark used to strip out market-wide moves via the market model.
MARKET_TICKER=SPY

# Default yfinance period string for analysis (e.g. 3mo, 6mo, 1y, 2y).
ANALYSIS_PERIOD=1y

# Minimum aligned news days / quiet days required before a verdict is issued.
MIN_NEWS_DAYS=5
MIN_QUIET_DAYS=20

# How long (seconds) an analysis result is cached in-memory per ticker+period.
CACHE_TTL_SECONDS=1800

# Comma-separated list of origins allowed to call the API (CORS).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
